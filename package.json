{
    "name": "ebp-tools",
    "version": "1.6.104",
    "description": "",
    "main": ".webpack/main",
    "scripts": {
        "install_npm": "npm install && cd angular && npm install",
        "lint": "eslint \"angular/src/**/*.ts\"",
        "lint:fix": "eslint \"angular/src/**/*.ts\" --fix && prettier --write \"angular/src/**/*.ts\"",
        "make": "cd ./angular && npx ng build && cd ../ && electron-forge make",
        "start": "concurrently \"cd ./angular && npx ng serve --port 4201\" \"electron ./electron/server.js\"",
        "start-ubuntu": "concurrently \"cd ./angular && npx ng serve --port 4201\" \"electron ./electron/server.js --no-sandbox\"",
        "test": "cd angular && npx jest",
        "start_live_client_windows": "ffmpeg -f gdigrab -framerate 10 -i desktop -vcodec libx264 -preset ultrafast -tune zerolatency -rtsp_transport tcp -f rtsp rtsp://192.168.1.30:8554/live",
        "start_live_client_macos": "ffmpeg -f avfoundation -framerate 10 -i \"3\" -vcodec libx264 -preset ultrafast -tune zerolatency -rtsp_transport tcp -f rtsp rtsp://192.168.1.30:8554/live"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/HeyHeyChicken/EBP-Tools.git"
    },
    "publish": {
        "provider": "github",
        "owner": "HeyHeyChicken",
        "repo": "EBP-Tools"
    },
    "keywords": [],
    "author": "Antoine Duval",
    "license": "See LICENSE.txt",
    "dependencies": {
        "discord-rpc": "^4.0.1",
        "electron-updater": "^6.7.3",
        "exceljs": "^4.4.0",
        "express": "^5.2.1",
        "get-port": "^7.1.0",
        "puppeteer-core": "^24.37.2",
        "registry-js": "^1.16.1",
        "socket.io-client": "^4.8.3"
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-deb": "^7.11.1",
        "@electron-forge/maker-dmg": "^7.11.1",
        "@electron-forge/maker-rpm": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
        "@electron-forge/plugin-fuses": "^7.11.1",
        "@electron-forge/plugin-webpack": "^7.11.1",
        "@electron-forge/publisher-github": "^7.11.1",
        "@eslint/js": "^9.39.2",
        "@vercel/webpack-asset-relocator-loader": "^1.10.0",
        "concurrently": "^9.2.1",
        "copy-webpack-plugin": "^13.0.1",
        "electron": "^40.2.1",
        "electron-squirrel-startup": "^1.0.1",
        "eslint": "^9.39.2",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0"
    }
}
